<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Database</title>
</head>

<body class="bg-zinc-950 text-white">

    <!-- Heading -->
    <h1 class="text-4xl font-bold text-center mt-10 mb-8">
        All Users
    </h1>

    <div class="nav mb-3 flex justify-start p-4">
        <a class="text-zinc-400 hover:text-white transition" href="/">Back to Homepage</a>
    </div>

    <!-- Users Container -->
    <div class="flex flex-wrap justify-start gap-6 p-6">

        <!-- User Card -->
        <% users.forEach(function(e) { %>
            <div
            class="w-80 bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden shadow-2xl hover:-translate-y-2 hover:border-blue-500 transition-all duration-300">

            <div class="relative">
                <img class="w-full h-52 object-cover bg-blue-600" src="<%= e.image %>" alt="">
                <div class="absolute inset-0 bg-gradient-to-t from-zinc-900 to-transparent"></div>
            </div>

            <div class="p-5">
                <h2 class="text-2xl font-bold"><%= e.name %></h2>
                <p class="text-zinc-400 mt-1 break-all"><%= e.email %></p>

                <div class="flex gap-3 mt-6">
                    <a href=""
                        class="flex-1 text-center bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-xl font-medium">
                        Edit User
                    </a>

                    <a href=""
                        class="flex-1 text-center bg-red-600 hover:bg-red-700 px-4 py-2 rounded-xl font-medium">
                        Delete
                    </a>
                </div>
            </div>
        </div>
        <% }) %>

    </div>

</body>

</html>